{
  "name": "yeelight-lightstrip-pro-controller",
  "version": "0.0.1",
  "description": "Control your Yeelight strip based on screen color and Antigravity status",
  "main": "main.js",
  "scripts": {
    "start": "xattr -cr node_modules/electron/dist/Electron.app 2>/dev/null; node_modules/electron/dist/Electron.app/Contents/MacOS/Electron .",
    "dev": "xattr -cr node_modules/electron/dist/Electron.app 2>/dev/null; node_modules/electron/dist/Electron.app/Contents/MacOS/Electron . --dev",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [],
  "author": "Light Strip Pro",
  "license": "MIT",
  "devDependencies": {
    "electron": "^22.3.27",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "me.ironfeet.com.yeelight-lightstrip-pro-controller",
    "productName": "YeeLight Lightstrip Pro Controller",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.png",
      "target": [
        "zip"
      ]
    },
    "directories": {
      "output": "release"
    }
  }
}